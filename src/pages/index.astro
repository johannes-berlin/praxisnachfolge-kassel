---
import "../styles/global.css";

// Wiederkehrende Utility-Bündel
const wrap = "mx-auto max-w-[1180px] px-[34px]";
const section = `${wrap} py-[74px]`; // warm: 74px statt 82px
const label = "text-[13px] font-medium uppercase tracking-[0.04em]";

const btnBase =
  "inline-block cursor-pointer rounded-full border px-[28px] py-[14px] text-[15px] font-medium transition-[transform,background] duration-200";
const btnDark = `${btnBase} bg-ink text-sand border-ink hover:-translate-y-px hover:bg-black`;
const btnSand = `${btnBase} bg-sand text-ink border-sand hover:-translate-y-px hover:bg-white hover:border-white`;
const linkPlus =
  "text-[15px] inline-flex items-center gap-[9px] before:content-['+'] before:text-gold before:text-[18px] hover:text-olive";

// Kennblatt-Daten
const kennblatt = [
  { k: "Standort", v: `Großraum Kassel / Nordhessen <span class="text-gold">(PLZ 34xxx)</span>` },
  { k: "Bestehend seit", v: `<span class="text-gold">[Jahr]</span> — über [X] Jahre am Markt` },
  { k: "Räume & Fläche", v: `ca. <span class="text-gold">[XX]</span> m², <span class="text-gold">[X]</span> Behandlungsräume<span class="text-gold"> [+ KGG-Bereich]</span>` },
  { k: "Zulassung", v: `Alle gesetzlichen Kassen<span class="text-gold"> [· Privatanteil ca. X %]</span>` },
  { k: "Leistungen", v: `KG, Manuelle Therapie<span class="text-gold"> [, MLD, KGG, Hausbesuche]</span>` },
  { k: "Team", v: `<span class="text-gold">[X]</span> Therapeut:innen + <span class="text-gold">[X]</span> Rezeption` },
  { k: "Auslastung", v: `Sehr gut<span class="text-gold"> [· mit Wartelisten]</span>` },
  { k: "Übergabe", v: `Zum <span class="text-gold">[Datum]</span> bzw. nach Absprache` },
  { k: "Einarbeitung", v: `<span class="text-gold">[X Wochen/Monate]</span> persönliche Begleitung möglich` },
];

const highlights = [
  { t: "Eingespieltes Team", p: "[Loyales, qualifiziertes Team, das nach Möglichkeit erhalten bleibt — kein Neuaufbau nötig.]" },
  { t: "Treuer Patientenstamm", p: "[Langjährige Patient:innen und eine stabile Zuweiserstruktur aus Orthopädie und Hausarztpraxen.]" },
  { t: "Sofort betriebsbereit", p: "[Moderne, gepflegte Ausstattung und eingespielte Abläufe — vom ersten Tag an arbeitsfähig.]" },
];

const steps = [
  { s: "Schritt eins", t: "Anfrage", p: "Sie schreiben kurz, wer Sie sind und welchen fachlichen Hintergrund Sie mitbringen." },
  { s: "Schritt zwei", t: "Unterlagen & NDA", p: "Nach einem ersten Kennenlernen erhalten Sie vertraulich das Detail-Exposé mit allen Kennzahlen." },
  { s: "Schritt drei", t: "Kennenlernen & Übergabe", p: "Persönliches Treffen, gemeinsame Übergabe und Einarbeitung in Ihrem Tempo." },
];

const faq = [
  { q: "Bleibt die Anonymität gewahrt?", a: "Ja. Auf dieser Seite und im Inserat erscheinen keine identifizierenden Angaben. Name, Adresse und konkrete Zahlen teilen wir erst im persönlichen Kontakt und nach gegenseitigem Einverständnis." },
  { q: "Was ist mit der Kassenzulassung?", a: "Die Praxis verfügt über die Zulassung aller gesetzlichen Kassen. Die Details zur Übertragung im Rahmen der Nachfolge besprechen wir individuell." },
  { q: "Ist eine Einarbeitung möglich?", a: "Ja, eine persönliche Übergabe mit Einarbeitungszeit ist ausdrücklich gewünscht — für einen reibungslosen Übergang bei Patient:innen und Team." },
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Diskretion: nicht indexieren, solange anonym -->
    <meta name="robots" content="noindex, nofollow" />
    <title>Praxisnachfolge · Großraum Kassel</title>
  </head>
  <body>
    <!-- ============ HERO (warm) ============ -->
    <div class="band-hero">
      <div class={wrap}>
        <!-- topbar — warm: py 26px -->
        <div class="flex items-center justify-between gap-4 border-b border-line py-[26px]">
          <span class="flex items-center gap-3 text-[13px] font-medium uppercase leading-[1.15] tracking-[0.02em]">
            <img src="/herkules.png" alt="" aria-hidden="true" class="h-[30px] w-[30px] flex-none object-contain" />
            Praxisnachfolge<br /><span class="text-gold">Großraum Kassel</span>
          </span>
          <div class="flex items-center gap-6 max-[860px]:gap-[14px]">
            <span class="inline-flex items-center gap-[7px] text-[13px] font-medium uppercase tracking-[0.04em] text-olive before:text-[15px] before:leading-none before:text-gold before:content-['+']">Vertraulich</span>
            <a href="#anfrage" class={btnDark}>Anfragen</a>
          </div>
        </div>

        <!-- hero -->
        <div class="reveal relative pt-[64px] text-center max-[860px]:pt-[46px]">
          <p class={`${label} mb-[30px] text-olive`}>Etablierte Physiotherapiepraxis · Nachfolge gesucht</p>
          <h1 class="relative z-[1] mx-auto max-w-[13ch] text-h1 font-normal leading-[0.95] tracking-[-0.03em] text-ink">
            Eine Praxis sucht ihre Nachfolge.
          </h1>
          <div class="hero-art relative z-[2] mx-auto mt-[-3.4rem] max-[860px]:mt-[-1.8rem]">
            <img src="/hero-art.jpg" alt="" class="mx-auto block h-auto max-h-[30rem] w-auto max-w-full object-contain" />
          </div>
          <div class="relative z-[3] mt-[-1.5rem] pt-[34px] pb-[78px]">
            <p class="mx-auto mb-[30px] max-w-[50ch] text-[1.18rem] leading-[1.5] text-body">
              Seit über [X] Jahren etabliert, gut ausgelastet und kassenzugelassen — mit treuem Patientenstamm und eingespieltem Team. Diskrete Übergabe in gute Hände, mit Zeit für eine saubere Einarbeitung.
            </p>
            <div class="flex flex-wrap items-center justify-center gap-x-[18px] gap-y-[14px]">
              <a href="#anfrage" class={btnDark}>Vertraulich anfragen</a>
              <a href="#kennblatt" class={linkPlus}>Eckdaten ansehen</a>
            </div>
          </div>
        </div>
      </div>
    </div>

    <main>
      <!-- STATEMENT — warm: gap 50px -->
      <section class={`reveal ${section} grid grid-cols-[1.25fr_0.9fr] items-start gap-[50px] max-[860px]:grid-cols-1 max-[860px]:gap-[28px]`}>
        <h2 class="max-w-[16ch] text-h2 font-normal leading-[1.04] tracking-[-0.022em]">
          Über Jahre gewachsen — bereit für die nächsten <span class="text-olive">Hände.</span>
        </h2>
        <div class="pt-[8px] [&>p+p]:mt-[16px]">
          <p class="text-[1.04rem] text-body">Diese Praxis trägt sich durch Vertrauen, Kontinuität und ein Team, das bleiben möchte. Genau das soll erhalten bleiben.</p>
          <p class="text-[1.04rem] text-body">Wir suchen keine schnelle Abwicklung, sondern eine Nachfolge, die Patient:innen und Team gerecht wird — diskret, in jedem Schritt.</p>
        </div>
      </section>

      <!-- KENNBLATT — warm: card 14/40/30, kb-top 24/0/18, row gap 20 -->
      <section id="kennblatt" class={`reveal ${section}`}>
        <div class="mb-[40px]"><span class={`${label} text-olive`}>Kennblatt</span></div>
        <div class="rounded-[22px] bg-cream px-[40px] pt-[14px] pb-[30px] max-[860px]:px-[24px] max-[860px]:pb-[24px]">
          <div class="flex items-baseline justify-between border-b border-line pt-[24px] pb-[18px] text-[13px] uppercase tracking-[0.04em] text-gold">
            <span class="font-medium text-olive">Angaben anonymisiert</span><span>Vertraulich</span>
          </div>
          {kennblatt.map((row) => (
            <div class="grid grid-cols-[210px_1fr] gap-[20px] border-b border-line-soft py-[16px] last-of-type:border-b-0 max-[860px]:grid-cols-1 max-[860px]:gap-[4px]">
              <div class="pt-[5px] text-[14px] text-olive max-[860px]:pt-0">{row.k}</div>
              <div class="text-[1.34rem] leading-[1.28] tracking-[-0.01em]" set:html={row.v} />
            </div>
          ))}
          <p class="mt-[24px] max-w-[62ch] text-[14px] text-muted">Konkrete Umsatz- und Finanzkennzahlen erhalten Sie nach erster Kontaktaufnahme und gegenseitigem Einverständnis (Vertraulichkeitsvereinbarung).</p>
        </div>
      </section>

      <!-- HIGHLIGHTS — colitem px 30, py 34 -->
      <section class={`reveal ${section}`}>
        <div class="mb-[40px]"><span class={`${label} text-olive`}>Was die Praxis besonders macht</span></div>
        <div class="grid grid-cols-3 border-t border-line max-[860px]:grid-cols-1">
          {highlights.map((h) => (
            <div class="border-r border-line-soft px-[30px] pt-[34px] pb-[34px] last:border-r-0 max-[860px]:border-r-0 max-[860px]:border-b max-[860px]:border-line-soft max-[860px]:px-0 max-[860px]:py-[28px] max-[860px]:last:border-b-0">
              <span class="mb-[20px] block text-[26px] leading-none text-gold">+</span>
              <h3 class="mb-[12px] text-[1.55rem] font-normal leading-[1.1] tracking-[-0.01em]">{h.t}</h3>
              <p class="text-[15px] leading-[1.5] text-muted">{h.p}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- PROCESS — warm: card 30/28/32, gap 22 -->
      <section class={`reveal ${section}`}>
        <div class="mb-[40px]"><span class={`${label} text-olive`}>So läuft die Übergabe</span></div>
        <div class="grid grid-cols-3 gap-[22px] max-[860px]:grid-cols-1">
          {steps.map((step) => (
            <div class="flex flex-col gap-[12px] rounded-[20px] bg-cream px-[28px] pt-[30px] pb-[32px]">
              <span class="text-[14px] text-gold">{step.s}</span>
              <h3 class="text-[1.45rem] font-normal leading-[1.12] tracking-[-0.01em]">{step.t}</h3>
              <p class="text-[14.5px] leading-[1.5] text-muted">{step.p}</p>
            </div>
          ))}
        </div>
      </section>

      <!-- FAQ — warm: trigger py 24, answer pb 26 -->
      <section class={`reveal ${section}`}>
        <div class="mb-[40px]"><span class={`${label} text-olive`}>Häufige Fragen</span></div>
        <div class="border-t border-line">
          {faq.map((item) => (
            <div class="border-b border-line-soft">
              <button
                type="button"
                aria-expanded="false"
                class="faq-trigger m-0 flex w-full cursor-pointer appearance-none items-center justify-between gap-5 border-0 bg-transparent px-[2px] py-[24px] text-left font-[inherit] text-[1.28rem] tracking-[-0.01em] text-inherit focus-visible:rounded-[4px] focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-olive"
              >
                <span>{item.q}</span>
                <span class="faq-icon flex-none text-[26px] leading-none text-gold transition-transform duration-[250ms]">+</span>
              </button>
              <div class="faq-answer">
                <p class="max-w-[62ch] px-[2px] pt-0 pb-[26px] text-[15.5px] text-muted">{item.a}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- CTA — warm: cta 56/56/60, h2 16/0/14, sub mb 36 -->
      <section id="anfrage" class={`reveal ${section}`}>
        <div class="my-[30px] rounded-[26px] bg-olive-deep px-[56px] pt-[56px] pb-[60px] text-white max-[860px]:px-[26px] max-[860px]:pt-[40px] max-[860px]:pb-[44px]">
          <p class={`${label} text-[#E9E4C4]`}>Vertraulich anfragen</p>
          <h2 class="mt-[16px] mb-[14px] max-w-[16ch] text-cta-h2 font-normal leading-[1.02] tracking-[-0.02em]">Lassen Sie uns sprechen.</h2>
          <p class="mb-[36px] max-w-[48ch] text-[rgba(255,255,255,0.82)]">Erzählen Sie kurz von sich — wir melden uns zeitnah und vertraulich zurück. Detailunterlagen folgen nach gegenseitigem Einverständnis.</p>

          <!-- Prototyp: sendet noch nichts. Anbindung: Netlify Function → Notion-Lead-DB → Resend. -->
          <form id="leadForm" novalidate>
            <div class="grid grid-cols-2 gap-[18px] max-[860px]:grid-cols-1">
              <div class="flex flex-col gap-[8px]">
                <label for="name" class="text-[13px] text-[rgba(255,255,255,0.8)]">Name</label>
                <input id="name" type="text" required class="w-full rounded-[10px] border border-[rgba(255,255,255,0.28)] bg-[rgba(255,255,255,0.1)] px-[15px] py-[14px] font-[inherit] text-[15.5px] text-white placeholder:text-[rgba(255,255,255,0.55)] focus:border-transparent focus:outline-2 focus:outline-offset-1 focus:outline-sand" />
              </div>
              <div class="flex flex-col gap-[8px]">
                <label for="email" class="text-[13px] text-[rgba(255,255,255,0.8)]">E-Mail</label>
                <input id="email" type="email" required class="w-full rounded-[10px] border border-[rgba(255,255,255,0.28)] bg-[rgba(255,255,255,0.1)] px-[15px] py-[14px] font-[inherit] text-[15.5px] text-white placeholder:text-[rgba(255,255,255,0.55)] focus:border-transparent focus:outline-2 focus:outline-offset-1 focus:outline-sand" />
              </div>
              <div class="flex flex-col gap-[8px]">
                <label for="tel" class="text-[13px] text-[rgba(255,255,255,0.8)]">Telefon <span class="text-[rgba(255,255,255,0.5)]">(optional)</span></label>
                <input id="tel" type="tel" class="w-full rounded-[10px] border border-[rgba(255,255,255,0.28)] bg-[rgba(255,255,255,0.1)] px-[15px] py-[14px] font-[inherit] text-[15.5px] text-white placeholder:text-[rgba(255,255,255,0.55)] focus:border-transparent focus:outline-2 focus:outline-offset-1 focus:outline-sand" />
              </div>
              <div class="flex flex-col gap-[8px]">
                <label for="role" class="text-[13px] text-[rgba(255,255,255,0.8)]">Aktuelle Tätigkeit <span class="text-[rgba(255,255,255,0.5)]">(optional)</span></label>
                <input id="role" type="text" placeholder="z. B. angestellte:r Physiotherapeut:in" class="w-full rounded-[10px] border border-[rgba(255,255,255,0.28)] bg-[rgba(255,255,255,0.1)] px-[15px] py-[14px] font-[inherit] text-[15.5px] text-white placeholder:text-[rgba(255,255,255,0.55)] focus:border-transparent focus:outline-2 focus:outline-offset-1 focus:outline-sand" />
              </div>
              <div class="col-span-full flex flex-col gap-[8px]">
                <label for="msg" class="text-[13px] text-[rgba(255,255,255,0.8)]">Ihr fachlicher Hintergrund &amp; Motivation</label>
                <textarea id="msg" placeholder="Kurz: Qualifikation, Erfahrung und warum Sie diese Praxis übernehmen möchten." class="min-h-[108px] w-full resize-y rounded-[10px] border border-[rgba(255,255,255,0.28)] bg-[rgba(255,255,255,0.1)] px-[15px] py-[14px] font-[inherit] text-[15.5px] text-white placeholder:text-[rgba(255,255,255,0.55)] focus:border-transparent focus:outline-2 focus:outline-offset-1 focus:outline-sand"></textarea>
              </div>
            </div>
            <div class="mt-[6px] flex items-start gap-[11px]">
              <input id="consent" type="checkbox" required class="mt-[4px] w-auto accent-sand" />
              <label for="consent" class="text-[13px] leading-[1.5] text-[rgba(255,255,255,0.8)]">Ich bin mit einer vertraulichen Kontaktaufnahme einverstanden. Meine Angaben werden ausschließlich zur Bearbeitung dieser Anfrage genutzt.</label>
            </div>
            <div class="mt-[26px] flex flex-wrap items-center gap-x-[24px] gap-y-[16px]">
              <button type="submit" class={btnSand}>Anfrage senden</button>
              <span class="max-w-[40ch] text-[12.5px] text-[rgba(255,255,255,0.62)]">Diskret. Keine Weitergabe an Dritte.</span>
            </div>
          </form>

          <div id="sent" class="hidden rounded-[14px] border border-[rgba(255,255,255,0.3)] bg-[rgba(255,255,255,0.1)] px-[30px] pt-[28px] pb-[28px]" role="status" aria-live="polite">
            <h3 class="mb-[8px] text-[1.5rem] font-normal">Vielen Dank — Ihre Anfrage ist notiert.</h3>
            <p class="text-[rgba(255,255,255,0.82)]">Wir melden uns zeitnah und vertraulich bei Ihnen zurück.</p>
          </div>
        </div>
      </section>
    </main>

    <footer class={`${wrap} border-t border-line pt-[40px] pb-[64px] text-[13.5px] text-faint`}>
      <div class="flex flex-wrap justify-between gap-[24px] [&>p+p]:mt-[8px]">
        <p>Diese Seite enthält bewusst keine identifizierenden Angaben.<br />Standort, Name und Zahlen folgen im persönlichen Kontakt.</p>
        <p>© <span id="yr"></span> · Vertrauliche Praxisnachfolge · Großraum Kassel</p>
      </div>
    </footer>

    <script>
      // Jahr
      const yr = document.getElementById("yr");
      if (yr) yr.textContent = String(new Date().getFullYear());

      // Scroll-Reveal
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("in");
              io.unobserve(e.target);
            }
          });
        },
        { threshold: 0.1 }
      );
      document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

      // FAQ-Akkordeon
      document.querySelectorAll<HTMLButtonElement>(".faq-trigger").forEach((btn) => {
        btn.addEventListener("click", () => {
          const open = btn.getAttribute("aria-expanded") === "true";
          btn.setAttribute("aria-expanded", String(!open));
          const ans = btn.nextElementSibling as HTMLElement | null;
          if (ans) ans.style.maxHeight = open ? "0px" : ans.scrollHeight + "px";
        });
      });

      // Formular-Prototyp
      const form = document.getElementById("leadForm") as HTMLFormElement | null;
      form?.addEventListener("submit", (ev) => {
        ev.preventDefault();
        if (!form.checkValidity()) {
          form.reportValidity();
          return;
        }
        form.style.display = "none";
        const sent = document.getElementById("sent");
        sent?.classList.remove("hidden");
        sent?.scrollIntoView({ behavior: "smooth", block: "center" });
      });
    </script>
  </body>
</html>
